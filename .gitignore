# Dependencies
node_modules/

# Build output
dist/

# Environment variables
.env

# Database WAL/SHM files (auto-generated by SQLite)
data/*-wal
data/*-shm

# ALL plant databases (uncomment if you want to block DBs)
# data/*.db

# SQLite database files at project root
*.sqlite

# Large debug/test output files
all_t_calls.txt
final_verification.txt
test_results.json
failed_tests.json

# Anonymization backup (contains un-anonymized real plant data)
data_backup_before_anonymize/

# Private archive for old scripts and logs
_archive_private/

# Log files
*.log
*.err

# OS files
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/

# Dev scripts (kept in _dev_scripts/ for reference)
# Uncomment below if you want to fully exclude from version control:
_dev_scripts/

# License system (PRIVATE — never distribute)
keygen.js
data/license.key

# Temp scripts
tmp_*

build/

# Deprecated archive (safe to delete later)
Deprecated/

# Screenshots & media (not source code)
Screenshots/

# Snapshots (database backups, generated at runtime)
snapshots/

# Import/reset snapshot files (auto-generated by DataBridge)
data/*.IMPORT_SNAP_*
data/*.RESET_SNAP_*

# Electron build output
electron-dist/

# OCR training data (large binary, download separately)
eng.traineddata

# Playwright runtime artifacts (auto-generated, not source code)
playwright-report/
test-results/

# Video recordings (marketing assets, not source code)
videos/

# Line count output
cloc.json

# Proprietary vendor manuals (PDFs, not redistributable)
Manuals/*.pdf

# Internal dev history / sprint planning docs
Artifacts/dev-history/

# QA test result archives (reference outdated multi-DB stress test configs)
Test Results/

# Corrupted database backup files (auto-generated during recovery)
data/*.corrupt

# ALL database backups and snapshots (contain real plant operational data)
data/backups/
data/snapshots/

# SSL certificates and private keys (NEVER commit these)
data/certs/

# Server-side database copies (runtime files, not source)
server/*.db
server/data/

# Extra runtime/log databases (auto-generated at runtime)
data/log.db
data/local-sqlite.db
data/studio_log.db
data/trier_os.db
