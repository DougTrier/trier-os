                "Description":     { "source": "DESCRIPTION",    "fallback": "EQUIP_DESC",    "type": "text",    "confidence": "confirmed" },
                "AssetType":       { "source": "EQUIP_TYPE",     "fallback": "TYPE_ID",       "type": "text",    "confidence": "confirmed" },
                "LocationID":      { "source": "LOCATION_ID",    "fallback": "LOCATION",      "type": "text",    "confidence": "confirmed" },
