{
    "id": "express",
    "name": "Express Maintenance (Dematic / Intellitrack)",
    "description": "Express Maintenance CMMS databases. Typically unencrypted .mdb format.",
    "sourceType": "access",
    "version": "1.0",
    "passwordProtected": false,
    "notes": "Express Maintenance uses straightforward table/column names. Column names vary slightly across versions — fallback fields cover common variants.",
    "tables": {
