                "ID":           { "source": "ITEM_NO",      "fallback": "ITEM_NUM",       "type": "text",    "confidence": "confirmed" },
                "Descript":     { "source": "DESCRIPTION",  "fallback": "ITEM_DESC",      "type": "text",    "confidence": "confirmed" },
