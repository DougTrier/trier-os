                "VendorID":     { "source": "VENDOR_ID",    "fallback": "SUPPLIER_ID",    "type": "text",    "confidence": "confirmed" },
                "Manufacturer": { "source": "MANUFACTURER",                               "type": "text",    "confidence": "confirmed" },
                "Model":        { "source": "MODEL_NO",     "fallback": "MODEL",          "type": "text",    "confidence": "confirmed" },
                "Comment":      { "source": "COMMENTS",     "fallback": "NOTES",          "type": "text",    "confidence": "confirmed" }
            }
        },
        "Vendors": {
            "sourceTable": "SUPPLIERS",
            "notes": "Supplier / vendor records.",
            "columns": {
                "ID":          { "source": "VENDOR_ID",    "fallback": "SUPPLIER_ID",   "type": "text",    "confidence": "confirmed" },
                "Description": { "source": "COMPANY_NAME", "fallback": "VENDOR_NAME",   "type": "text",    "confidence": "confirmed" },
                "Address":     { "source": "ADDRESS",      "fallback": "ADDR1",         "type": "text",    "confidence": "confirmed" },
                "City":        { "source": "CITY",                                       "type": "text",    "confidence": "confirmed" },
                "State":       { "source": "STATE",                                      "type": "text",    "confidence": "confirmed" },
                "Zip":         { "source": "ZIP",          "fallback": "ZIP_CODE",      "type": "text",    "confidence": "confirmed" },
                "Phone":       { "source": "PHONE",        "fallback": "PHONE_NO",      "type": "text",    "confidence": "confirmed" },
                "Scontact":    { "source": "CONTACT",      "fallback": "CONTACT_NAME",  "type": "text",    "confidence": "confirmed" },
                "Email":       { "source": "EMAIL",        "fallback": "EMAIL_ADDR",    "type": "text",    "confidence": "confirmed" },
                "Comment":     { "source": "COMMENTS",     "fallback": "NOTES",         "type": "text",    "confidence": "confirmed" },
                "Vendor":      { "source": null,           "default": true,             "type": "boolean", "confidence": "confirmed" }
            }
        },
        "Procedures": {
            "sourceTable": "PREVENTIVE",
            "notes": "Preventive maintenance task masters.",
            "columns": {
                "ID":       { "source": "PM_ID",       "fallback": "TASK_ID",    "type": "text",    "confidence": "confirmed" },
                "Descript": { "source": "DESCRIPTION", "fallback": "PM_DESC",   "type": "text",    "confidence": "confirmed" },
                "AstID":    { "source": "EQUIP_ID",    "fallback": "EQUIPMENT_ID", "type": "text", "confidence": "confirmed" },
                "Priority": { "source": "PRIORITY",                              "type": "integer", "confidence": "confirmed" },
                "Comment":  { "source": "COMMENTS",    "fallback": "NOTES",     "type": "text",    "confidence": "confirmed" }
            }
        },
        "WorkParts": {
            "sourceTable": "WORKORDERPARTS",
            "notes": "Parts used on work orders.",
            "columns": {
                "WorkID":   { "source": "WO_NO",      "fallback": "WO_NUM",    "type": "text", "confidence": "confirmed" },
                "PartID":   { "source": "ITEM_NO",    "fallback": "ITEM_NUM",  "type": "text", "confidence": "confirmed" },
                "Quantity": { "source": "QTY_USED",   "fallback": "QUANTITY",  "type": "real", "confidence": "confirmed" },
                "UnitCost": { "source": "UNIT_COST",                           "type": "real", "confidence": "confirmed" },
                "Comment":  { "source": "COMMENTS",   "fallback": "NOTES",    "type": "text", "confidence": "confirmed" }
            }
        },
        "WorkLabor": {
            "sourceTable": "WORKORDERLABOR",
            "notes": "Labor entries on work orders.",
            "columns": {
                "WorkID":  { "source": "WO_NO",        "fallback": "WO_NUM",      "type": "text", "confidence": "confirmed" },
                "AddrID":  { "source": "EMPLOYEE_ID",  "fallback": "TECH_ID",     "type": "text", "confidence": "confirmed" },
                "DateRef": { "source": "WORK_DATE",    "fallback": "LABOR_DATE",  "type": "date", "confidence": "confirmed" },
                "RegHrs":  { "source": "REG_HOURS",    "fallback": "REGULAR_HRS", "type": "real", "confidence": "confirmed" },
                "OTHrs":   { "source": "OT_HOURS",     "fallback": "OVERTIME_HRS","type": "real", "confidence": "confirmed" },
                "Comment": { "source": "COMMENTS",     "fallback": "NOTES",       "type": "text", "confidence": "confirmed" }
            }
        },
        "Locations": {
            "sourceTable": "LOCATIONS",
            "columns": {
                "ID":          { "source": "LOCATION_ID",   "fallback": "LOCATION",   "type": "text", "confidence": "confirmed" },
                "Description": { "source": "DESCRIPTION",   "fallback": "LOCATION_NAME", "type": "text", "confidence": "confirmed" },
