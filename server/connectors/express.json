                "RequestBy":    { "source": "REQUEST_BY",   "fallback": "REQUESTED_BY",   "type": "text",    "confidence": "confirmed" },
                "AddDate":      { "source": "REQUEST_DATE", "fallback": "CREATE_DATE",    "type": "date",    "confidence": "confirmed" },
