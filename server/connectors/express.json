                "Manufacturer":    { "source": "MANUFACTURER",                                "type": "text",    "confidence": "confirmed" },
                "Model":           { "source": "MODEL_NO",       "fallback": "MODEL",         "type": "text",    "confidence": "confirmed" },
                "Serial":          { "source": "SERIAL_NO",      "fallback": "SERIAL_NUM",    "type": "text",    "confidence": "confirmed" },
                "AssetTag":        { "source": "ASSET_TAG",      "fallback": "ASSET_NUM",     "type": "text",    "confidence": "confirmed" },
                "InstallDate":     { "source": "INSTALL_DATE",   "fallback": "STARTUP_DATE",  "type": "date",    "confidence": "confirmed" },
                "PurchaseDate":    { "source": "PURCHASE_DATE",  "fallback": "PURCH_DATE",    "type": "date",    "confidence": "confirmed" },
                "InstallCost":     { "source": "PURCHASE_PRICE", "fallback": "ORIGINAL_COST", "type": "real",    "confidence": "confirmed" },
                "ReplacementCost": { "source": "REPLACE_COST",   "fallback": "REPLACE_VALUE", "type": "real",    "confidence": "confirmed" },
                "Priority":        { "source": "PRIORITY",                                    "type": "integer", "confidence": "confirmed" },
                "Active":          { "source": "ACTIVE",         "fallback": "IN_SERVICE",    "type": "integer", "confidence": "confirmed" },
                "Comment":         { "source": "COMMENTS",       "fallback": "NOTES",         "type": "text",    "confidence": "confirmed" }
            }
        },
        "Work": {
            "sourceTable": "WORKORDERS",
