# ─────────────────────────────────────────────
# Trier OS — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Core
# JWT_SECRET — signs all session tokens. Must be a random string ≥ 64 characters.
# If this value is missing, weak, or matches the placeholder, the server auto-generates
# a cryptographically strong secret and writes it back to .env at boot — so sessions
# survive restarts automatically. Set this explicitly in production to control rotation.
JWT_SECRET=YOUR_SECURE_RANDOM_STRING_HERE_MINIMUM_64_CHARS

# HUB_TOKEN_SECRET — signs the LAN-hub WebSocket token stored in localStorage.
# MUST be distinct from JWT_SECRET so a stolen localStorage token cannot be
# replayed against the main API. Auto-generated on first boot in dev; required
# (and must not equal JWT_SECRET) in production — server will refuse to start
# otherwise.
HUB_TOKEN_SECRET=YOUR_DISTINCT_HUB_SECRET_HERE_MINIMUM_64_CHARS

PORT=3000
NODE_ENV=development

# ─── CORS Whitelisting (SEC-005) ──────────────
# Comma-separated list of allowed origins.
# Format: http(s)://hostname:port — no trailing slashes.
# Add every IP/hostname that will access this server.
ALLOWED_ORIGINS=http://localhost:5173, http://your-server.local:3000

# DISABLE_LAN_CORS — set to "1" to disable the implicit LAN origin
# allowance (192.168.*.*, 10.*.*.*, 172.16–31.*.*). The default
# deployment model is factory-intranet and allows LAN origins so
# mobile scanners can connect without per-device config. Air-gapped
# or hardened installs should set this to lock CORS to ALLOWED_ORIGINS
# only. See SECURITY.md for the trust-boundary discussion.
# DISABLE_LAN_CORS=1

# ─── GIS / 3D Globe Maps ──────────────────────
# Required for the Cesium-powered asset map and floor plan globe.
# Get a free token at https://cesium.com/ion/tokens
# CESIUM_ION_TOKEN=your-token-here

# ─── HTTPS / SSL (optional — LAN deployments) ─
# If not provided, the server runs on HTTP.
# For production LAN use, point to your cert files.
# SSL_CERT=/path/to/cert.pem
# SSL_KEY=/path/to/key.pem

# ─── Database ─────────────────────────────────
# Defaults to ./data relative to the project root.
# Override if your plant databases live elsewhere.
# DATABASE_PATH=./data

# ─── Logging ──────────────────────────────────
# Options: error | warn | info | debug
LOG_LEVEL=info

# ─── Email Notifications (optional) ──────────
# SMTP settings for work order alerts and escalations.
# SMTP_HOST=smtp.your-company.com
# SMTP_PORT=587
# SMTP_USER=noreply@your-company.com
# SMTP_PASS=your-smtp-password

# ─── Gemini API (parts catalog automation) ───────────────────────────────
# Free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_key_here
